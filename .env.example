# Скопируй этот файл в .env и заполни реальными значениями

# Telegram бот (получить у @BotFather)
BOT_TOKEN=

# PostgreSQL — Supabase (Settings → Database → Connection string)
# Важно: префикс postgresql+asyncpg://, не postgresql://
DATABASE_URL=postgresql+asyncpg://postgres:[пароль]@db.[id].supabase.co:5432/postgres

# ЮKassa (yookassa.ru → Интеграция → HTTP-уведомления)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Telegram ID администратора бота (узнать у @userinfobot)
ADMIN_ID=

# Redis — Upstash (upstash.com → Redis → Connect → .env)
# Нужен для хранения FSM-состояний на Vercel
REDIS_URL=rediss://default:[пароль]@[host].upstash.io:6379

# URL webhook для Telegram (заполнить после первого деплоя на Vercel)
WEBHOOK_URL=https://your-project.vercel.app/api/webhook

# Секрет для защиты Cron-эндпоинтов (любая случайная строка)
# Верcel Cron Jobs передаёт её в заголовке Authorization
CRON_SECRET=
