# Скопируй этот файл в .env и заполни реальными значениями

# Telegram бот (получить у @BotFather)
BOT_TOKEN=

# PostgreSQL — Supabase (Connect → Transaction pooler → URI)
# Важно: префикс postgresql+asyncpg://, порт 5432 (Session pooler)
DATABASE_URL=postgresql+asyncpg://postgres.[id]:[пароль]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ЮKassa (yookassa.ru → Интеграция → HTTP-уведомления)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Telegram ID администратора бота (узнать у @userinfobot)
ADMIN_ID=

# Redis — Upstash (upstash.com → Redis → Connect → TCP)
# Нужен для хранения FSM-состояний в продакшне (Yandex Cloud Functions)
# Локально можно не заполнять — будет использоваться MemoryStorage
REDIS_URL=rediss://default:[пароль]@[host].upstash.io:6379

# URL webhook для Telegram — адрес функции yc/webhook.py из Yandex API Gateway
# Заполнить после первого деплоя на Yandex Cloud
WEBHOOK_URL=https://[id].apigw.yandexcloud.net/webhook

# Секрет для защиты cron-эндпоинтов yc/reminders.py и yc/results.py
# Yandex Cloud Scheduler передаёт его в заголовке Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
